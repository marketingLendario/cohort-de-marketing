# ===================================================================
# .env.example — Cohort de Marketing (Aula 01)
# ===================================================================
#
# COMO USAR:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha as chaves abaixo conforme for usando cada skill
# 3. NUNCA commite o .env preenchido (ele esta no .gitignore)
#
# REGRA GERAL:
# - Todas as chaves sao OPCIONAIS. As skills funcionam sem elas em
#   "modo offline" (voce cola o material, a IA analisa)
# - As chaves so aceleram a coleta automatica
# - Se nao tiver chave, a skill avisa e cai para o modo manual
#
# ===================================================================


# ===================================================================
# META AD LIBRARY (anuncios pagos do Facebook e Instagram)
# ===================================================================
# Usado por: /espiao-do-concorrente
# Para que serve: puxa anuncios ativos de qualquer pagina publica
#                 automaticamente, sem precisar abrir o navegador
#
# COMO PEGAR (gratuito, 5 minutos):
# 1. Acesse: https://www.facebook.com/ads/library/api/
# 2. Clique em "Get Started" / "Get API Access"
# 3. Faca login com sua conta Facebook (precisa ter perfil verificado:
#    confirmar identidade com documento, ja foi feito uma vez)
# 4. Aceite os termos da API
# 5. Va em "Tools" e gere um token de acesso
# 6. Copie o token e cole aqui na linha abaixo
#
# SEM ESSE TOKEN: a skill ainda funciona. Ela abre a URL publica
# (facebook.com/ads/library) no navegador, voce copia e cola os textos
# dos anuncios no chat, e a analise e a mesma.
#
META_AD_LIBRARY_TOKEN=


# ===================================================================
# APIFY (scraping de Instagram, TikTok, LinkedIn, Reddit, etc.)
# ===================================================================
# Usado por: /trend-hunting (OBRIGATORIO), /espiao-do-concorrente e
#            /pesquisa-de-avatar (opcional nessas duas)
# Para que serve: scraping automatico de perfis sociais, comentarios,
#                 reviews em escala
#
# COMO PEGAR (gratis para uso leve: plano Free da US$ 5/mes de credito,
# sem cartao; uso medio cai no Starter US$ 29/mes):
# 1. Acesse: https://console.apify.com/sign-up
# 2. Crie conta gratuita (sem cartao)
# 3. Va em Settings -> Integrations -> API Tokens
# 4. Copie o "Personal API token" e cole abaixo
# 5. Configure o Apify MCP no Claude Code para usar dentro do chat:
#    claude mcp add apify --env APIFY_API_TOKEN=$APIFY_API_TOKEN -- npx -y @apify/actors-mcp-server
#    (referencia: https://docs.apify.com/platform/integrations/mcp)
#
# OBRIGATORIO PARA /trend-hunting: essa skill nao roda sem o Apify
# (token + MCP). Ela usa o Apify para raspar Reels, TikTok e perfis de
# concorrentes.
# OPCIONAL NAS OUTRAS: /espiao-do-concorrente e /pesquisa-de-avatar caem
# para coleta manual sem essa chave (voce cola os posts, elas analisam).
#
APIFY_API_TOKEN=


# ===================================================================
# ANTHROPIC API (so se for usar fora do Claude Code, via SDK)
# ===================================================================
# Usado por: scripts Python que chamam Claude diretamente
# Para que serve: rodar analises programaticamente sem precisar
#                 abrir o Claude Code
#
# COMO PEGAR:
# 1. Acesse: https://console.anthropic.com/
# 2. Va em Settings -> API Keys -> Create Key
# 3. Cole abaixo
#
# SE VOCE SO VAI USAR DENTRO DO CLAUDE CODE: nao precisa.
# O Claude Code ja tem autenticacao propria.
#
ANTHROPIC_API_KEY=


# ===================================================================
# OPENAI API (so se quiser usar GPT em paralelo ao Claude)
# ===================================================================
# Usado por: skills que oferecem fallback para GPT
# Para que serve: alternativa ao Claude para quem prefere ChatGPT
#
# COMO PEGAR:
# 1. Acesse: https://platform.openai.com/api-keys
# 2. Create new secret key
# 3. Cole abaixo
#
# SE SO USA CLAUDE: nao precisa.
#
OPENAI_API_KEY=


# ===================================================================
# FIGMA (opcional, para versao visual do swipe file)
# ===================================================================
# Usado por: /swipe-file
# Para que serve: criar e organizar criativos winners no Figma
#                 em vez de markdown
#
# COMO PEGAR:
# 1. Acesse: https://www.figma.com/developers/api#access-tokens
# 2. Settings -> Personal access tokens -> Create new token
# 3. Cole abaixo
# 4. (Opcional) Pegue o FILE_ID do arquivo onde quer salvar (da URL
#    do arquivo Figma, parte apos /file/)
#
# SEM CHAVE: o swipe file funciona em markdown puro (pasta com
# screenshots + .md por criativo)
#
FIGMA_API_KEY=
FIGMA_FILE_ID=


# ===================================================================
# COMO A SKILL SABE QUE EXISTE CHAVE?
# ===================================================================
# Os scripts Python das skills leem essas variaveis assim:
#
#   import os
#   token = os.environ.get("META_AD_LIBRARY_TOKEN", "").strip()
#   if token:
#       # usa API automatica
#   else:
#       # cai para modo manual
#
# Para o sistema enxergar o .env, voce precisa carregar antes de rodar:
#   No Mac/Linux:  export $(cat .env | xargs)
#   Mais facil:    use 'direnv' (https://direnv.net) que carrega
#                  automatico ao entrar na pasta
#
# Dentro do Claude Code, voce pode pedir para a skill ler o .env
# usando os scripts dela (eles ja sabem fazer isso).
#
# ===================================================================
