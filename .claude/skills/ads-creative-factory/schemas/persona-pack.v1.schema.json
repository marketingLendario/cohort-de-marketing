{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ads-creative-factory.invalid/schemas/persona-pack.v1.schema.json",
  "title": "Persona pack contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_type",
    "id",
    "identity",
    "voice",
    "consent",
    "assets",
    "rights"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "pack_type": {"const": "persona"},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "role", "description"],
      "properties": {
        "display_name": {"type": "string", "minLength": 1},
        "role": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "topics", "avoid"],
      "properties": {
        "tone": {"type": "string", "minLength": 1},
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "avoid": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["granted", "reference"],
      "properties": {
        "granted": {"const": true},
        "reference": {"type": "string", "minLength": 8}
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "path", "kind", "rights_id", "sha256"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"},
              "path": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
              },
              "kind": {"type": "string", "enum": ["photo", "reference", "font", "other"]},
              "rights_id": {"type": "string", "minLength": 1},
              "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            }
          }
        }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redistributable", "notice", "licenses"],
      "properties": {
        "redistributable": {"type": "boolean"},
        "notice": {"type": "string", "minLength": 1},
        "licenses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "spdx", "redistributable", "notice"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"},
              "name": {"type": "string", "minLength": 1},
              "spdx": {"type": "string", "minLength": 1},
              "redistributable": {"type": "boolean"},
              "notice": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
