# services/meta-ads/.env.example
#
# This service does NOT read its own .env. It reads ~/Downloads/apps/.env.{spoke}
# for each spoke, expecting variables prefixed with {SPOKE_UPPER_SNAKE}_META_*.
#
# This file documents what each spoke's .env should contain.
#
# Reference: docs/migration/META-ADS-SPOKE-ONBOARDING-PLAYBOOK.md
# Story: STORY-152.2

# ============================================================================
# Required for every spoke (REQUIRED — wrapper exits 2 if missing)
# ============================================================================

# System User access token (preferred) or User token with marketing scopes.
# Generate: Meta Business Suite > Settings > Users > System Users > Generate New Token
# Required scopes (7): business_management, ads_management, pages_show_list,
#   pages_read_engagement, pages_manage_ads, catalog_management, read_insights
#                  (or ads_read as superset)
{SPOKE}_META_ACCESS_TOKEN=EAA...

# Ad Account ID (numeric, no 'act_' prefix — wrapper adds it automatically)
# Find via: meta ads adaccount list (after token works)
{SPOKE}_META_AD_ACCOUNT_ID=1234567890

# ============================================================================
# Optional (used by some commands)
# ============================================================================

# Business Manager ID — required by 'meta ads dataset' commands
{SPOKE}_META_BUSINESS_MANAGER_ID=1234567890

# ============================================================================
# Helpful but not consumed by the CLI directly
# ============================================================================

# App credentials — useful for /debug_token validation and OAuth flows
{SPOKE}_META_APP_ID=1234567890
{SPOKE}_META_APP_SECRET=abc123def456

# Pixel — for Conversions API and dataset commands
{SPOKE}_META_PIXEL_ID=1234567890

# Conversions API token — separate from SYSTEM_USER for least-privilege CAPI events
{SPOKE}_META_CAPI_TOKEN=EAA...

# Page / Instagram for ad creative creation
{SPOKE}_FACEBOOK_PAGE_ID=1234567890
{SPOKE}_INSTAGRAM_BUSINESS_ACCOUNT_ID=17841...

# Instagram OAuth (separate flow from Marketing API)
{SPOKE}_INSTAGRAM_APP_ID=1234567890
{SPOKE}_INSTAGRAM_APP_SECRET=abc123def456
{SPOKE}_INSTAGRAM_LOGIN_TOKEN=IGAA...

# Maximum duration for a read/check/pass-through command before fail-closed.
META_ADS_TIMEOUT_MS=30000
