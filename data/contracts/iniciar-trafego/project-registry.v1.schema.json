{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-registry.v1",
  "type": "object",
  "required": ["schemaVersion", "createdAt", "updatedAt", "projects"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "projects": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "schemaVersion",
          "projectId",
          "slug",
          "displayName",
          "projectRoot",
          "projectRootNormalized",
          "rootFingerprint",
          "pathFingerprint",
          "manifestHash",
          "candidateId",
          "slugCollisionWith",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "schemaVersion": { "const": "1.0.0" },
          "projectId": { "type": "string", "minLength": 8 },
          "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$" },
          "displayName": { "type": "string", "minLength": 1 },
          "projectRoot": { "type": "string", "minLength": 1 },
          "projectRootNormalized": { "type": "string", "minLength": 1 },
          "rootRelative": { "type": ["string", "null"] },
          "rootFingerprint": { "type": "string", "pattern": "^[a-f0-9]{24}$" },
          "pathFingerprint": { "type": "string", "pattern": "^cand_[a-f0-9]{16}$" },
          "manifestHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "candidateId": { "type": "string", "pattern": "^cand_[a-f0-9]{16}$" },
          "bindings": { "type": ["object", "null"] },
          "lastRunState": {
            "anyOf": [
              { "type": "object" },
              { "type": "string" },
              { "type": "null" }
            ]
          },
          "slugCollisionWith": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "movedFrom": { "type": ["string", "null"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
