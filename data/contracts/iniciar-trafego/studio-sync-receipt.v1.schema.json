{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "studio-sync-receipt.v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "receiptId",
    "sourceProjectId",
    "sourceProjectSlug",
    "proposalId",
    "proposalHash",
    "studioProjectId",
    "campaignId",
    "panelHash",
    "readbackOk",
    "deepLink",
    "syncedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "receiptId": { "type": "string", "minLength": 8 },
    "sourceProjectId": { "type": "string", "minLength": 8 },
    "sourceProjectSlug": { "type": "string", "minLength": 1 },
    "proposalId": { "type": "string", "minLength": 8 },
    "proposalHash": { "type": "string", "minLength": 16 },
    "studioProjectId": { "type": "string", "minLength": 8 },
    "campaignId": { "type": "string", "minLength": 8 },
    "briefRevision": { "type": "integer", "minimum": 1 },
    "campaignRevision": { "type": "integer", "minimum": 1 },
    "panelHash": { "type": "string", "minLength": 16 },
    "angleHashes": { "type": "array", "items": { "type": "string" } },
    "readbackOk": { "type": "boolean" },
    "deepLink": { "type": "string", "format": "uri" },
    "syncedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
