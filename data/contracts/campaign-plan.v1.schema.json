{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketinglendario.local/cohort/campaign-plan.v1.schema.json",
  "title": "Campaign Plan Revision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "schemaVersion",
    "id",
    "projectId",
    "campaignId",
    "revision",
    "sourceBrief",
    "platform",
    "objective",
    "budget",
    "angles",
    "finalists",
    "tracking",
    "structure",
    "manualSubmission",
    "overrides"
  ],
  "properties": {
    "contract": { "type": "string", "const": "CampaignPlan" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "campaignId": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "sourceBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "revision": { "type": "integer", "minimum": 1 }
      }
    },
    "platform": { "type": "string", "const": "meta" },
    "objective": { "type": "string", "enum": ["sales", "leads"] },
    "landingPageUrl": { "type": "string", "format": "uri" },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["daily", "periodDays", "currency"],
      "properties": {
        "daily": { "type": "number", "minimum": 20 },
        "periodDays": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string", "const": "BRL" }
      }
    },
    "angles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "awarenessLevel", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "awarenessLevel": { "type": "integer", "minimum": 1, "maximum": 5 },
          "source": { "type": "string", "enum": ["brief", "artifact", "human"] }
        }
      }
    },
    "finalists": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "angleId", "hook", "copy", "format", "selectedByHuman"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "angleId": { "type": "string", "minLength": 1 },
          "hook": { "type": "string", "minLength": 1 },
          "copy": { "type": "string", "minLength": 1 },
          "format": { "type": "string", "enum": ["feed", "reels-9x16"] },
          "selectedByHuman": { "type": "boolean", "const": true }
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "criticalItemsConfirmed", "checks"],
      "properties": {
        "status": { "type": "string", "enum": ["PENDING", "OK", "PARCIAL", "CRITICO"] },
        "criticalItemsConfirmed": { "type": "boolean" },
        "auditArtifactId": { "type": "string", "minLength": 1 },
        "checks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "evidence", "critical"],
            "properties": {
              "value": { "type": ["boolean", "null"] },
              "evidence": { "type": "string" },
              "critical": { "type": "boolean" }
            }
          }
        }
      }
    },
    "structure": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schemaVersion", "optimization", "audience", "creativeIds"],
          "properties": {
            "schemaVersion": { "type": "string", "const": "1.0.0" },
            "optimization": { "type": "string", "const": "conversion" },
            "audience": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "umbrellaInterest"],
              "properties": {
                "mode": { "type": "string", "const": "broad_cold_advantage_plus" },
                "umbrellaInterest": { "type": ["string", "null"], "minLength": 1 }
              }
            },
            "creativeIds": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true,
              "maxItems": 3
            }
          }
        }
      ]
    },
    "manualSubmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["not_ready", "ready", "confirmed_by_human"] },
        "confirmedAt": { "type": "string", "format": "date-time" },
        "confirmedBy": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "confirmed_by_human" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "confirmedAt": { "type": "string", "format": "date-time" },
              "confirmedBy": { "type": "string", "minLength": 1 }
            },
            "required": ["confirmedAt", "confirmedBy"]
          }
        }
      ]
    },
    "overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value", "reason", "updatedAt"],
        "properties": {
          "value": { "const": true },
          "reason": { "type": "string", "minLength": 1 },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
