{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketinglendario.local/cohort/project-brief.v1.schema.json",
  "title": "Project Brief Revision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "workspaceId",
    "projectId",
    "revision",
    "status",
    "createdAt",
    "updatedAt",
    "data",
    "fieldSources"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "superseded"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "$ref": "https://marketinglendario.local/cohort/project-brief.schema.json",
      "description": "Os 120 campos canônicos são reutilizados por referência; fieldMeta migra para fieldSources.",
      "properties": {
        "fieldMeta": false
      }
    },
    "fieldSources": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "format": "canonical-field-path"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "confirmation", "updatedAt"],
        "properties": {
          "source": { "type": "string", "enum": ["user", "artifact", "inferred", "migration"] },
          "confirmation": { "type": "string", "enum": ["confirmed", "pending", "not_applicable"] },
          "sourceArtifactId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "format": "portable-artifact-reference"
          },
          "sourceRevisionId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
