{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketinglendario.local/cohort/epic-9-field-observation.schema.json",
  "title": "Epic 9 field usability observation",
  "description": "Contrato sanitizado para observação humana ou proxy explicitamente identificado da jornada da Aula 3. Não armazena identidade, contato, credenciais, conteúdo privado ou texto livre bruto do participante.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "storyId", "status", "privacy", "session", "steps", "findings", "recommendation"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "storyId": { "const": "9.W3.1" },
    "status": { "enum": ["pending", "completed"] },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sanitized", "containsPii", "containsSecrets", "containsPrivateContent", "rawRecordingStored"],
      "properties": {
        "sanitized": { "const": true },
        "containsPii": { "const": false },
        "containsSecrets": { "const": false },
        "containsPrivateContent": { "const": false },
        "rawRecordingStored": { "const": false },
        "redactionNotes": { "type": "array", "items": { "$ref": "#/$defs/safeNote" }, "uniqueItems": true }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "operatorProfile", "consent", "developmentAssistance", "startedAt", "endedAt"],
      "properties": {
        "sessionId": { "type": ["string", "null"], "pattern": "^field-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{2}$" },
        "operatorProfile": { "enum": ["pending", "target-nontechnical", "codex-operator-proxy"] },
        "consent": { "enum": ["pending", "granted"] },
        "developmentAssistance": { "enum": ["not-observed", "none", "provided"] },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "endedAt": { "type": ["string", "null"], "format": "date-time" },
        "environment": { "enum": ["pending", "local-marketing-studio"] },
        "observerRole": { "enum": ["pending", "non-intervening-observer", "automated-proxy"] }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/$defs/step" },
      "allOf": [
        { "contains": { "type": "object", "properties": { "id": { "const": "open-project" } }, "required": ["id"] }, "minContains": 1 },
        { "contains": { "type": "object", "properties": { "id": { "const": "zelador" } }, "required": ["id"] }, "minContains": 1 },
        { "contains": { "type": "object", "properties": { "id": { "const": "briefista-curation" } }, "required": ["id"] }, "minContains": 1 },
        { "contains": { "type": "object", "properties": { "id": { "const": "estruturador" } }, "required": ["id"] }, "minContains": 1 },
        { "contains": { "type": "object", "properties": { "id": { "const": "manual-upload" } }, "required": ["id"] }, "minContains": 1 },
        { "contains": { "type": "object", "properties": { "id": { "const": "leitor" } }, "required": ["id"] }, "minContains": 1 },
        { "contains": { "type": "object", "properties": { "id": { "const": "diagnosticador" } }, "required": ["id"] }, "minContains": 1 }
      ]
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" },
      "uniqueItems": true
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate", "basis", "metricsArePromises"],
      "properties": {
        "gate": { "enum": ["pending-field-observation", "block", "conditional-go", "go"] },
        "basis": { "$ref": "#/$defs/safeNote" },
        "metricsArePromises": { "const": false },
        "realityCheck": { "$ref": "#/$defs/safeNote" }
      }
    }
  },
  "$defs": {
    "safeNote": { "type": "string", "minLength": 1, "maxLength": 500 },
    "countOrNull": { "type": ["integer", "null"], "minimum": 0 },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "status", "durationSeconds", "hesitationCount", "blockageCount", "recoveryCount", "result", "notes"],
      "properties": {
        "id": { "enum": ["open-project", "zelador", "briefista-curation", "estruturador", "manual-upload", "leitor", "diagnosticador"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "status": { "enum": ["pending", "completed", "blocked", "abandoned"] },
        "durationSeconds": { "type": ["integer", "null"], "minimum": 0 },
        "hesitationCount": { "$ref": "#/$defs/countOrNull" },
        "blockageCount": { "$ref": "#/$defs/countOrNull" },
        "recoveryCount": { "$ref": "#/$defs/countOrNull" },
        "result": { "enum": ["not-observed", "success", "partial", "failure"] },
        "notes": { "type": "array", "items": { "$ref": "#/$defs/safeNote" }, "uniqueItems": true }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "stepId", "classification", "observation", "impact", "recommendedAction"],
      "properties": {
        "id": { "type": "string", "pattern": "^F-[0-9]{2}$" },
        "stepId": { "enum": ["open-project", "zelador", "briefista-curation", "estruturador", "manual-upload", "leitor", "diagnosticador"] },
        "classification": { "enum": ["blocker", "pre-go-live", "backlog"] },
        "observation": { "$ref": "#/$defs/safeNote" },
        "impact": { "$ref": "#/$defs/safeNote" },
        "recommendedAction": { "$ref": "#/$defs/safeNote" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "pending" } }, "required": ["status"] },
      "then": {
        "type": "object",
        "properties": {
          "session": {
            "type": "object",
            "properties": {
              "sessionId": { "const": null }, "operatorProfile": { "const": "pending" }, "consent": { "const": "pending" },
              "developmentAssistance": { "const": "not-observed" }, "startedAt": { "const": null }, "endedAt": { "const": null }
            }
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": { "const": "pending" },
                "durationSeconds": { "const": null },
                "hesitationCount": { "const": null },
                "blockageCount": { "const": null },
                "recoveryCount": { "const": null },
                "result": { "const": "not-observed" },
                "notes": { "type": "array", "maxItems": 0 }
              }
            }
          },
          "findings": { "type": "array", "maxItems": 0 },
          "recommendation": { "type": "object", "properties": { "gate": { "const": "pending-field-observation" } } }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "completed" } }, "required": ["status"] },
      "then": {
        "type": "object",
        "properties": {
          "session": {
            "type": "object",
            "properties": {
              "sessionId": { "type": "string" }, "operatorProfile": { "enum": ["target-nontechnical", "codex-operator-proxy"] }, "consent": { "const": "granted" },
              "developmentAssistance": { "enum": ["none", "provided"] }, "startedAt": { "type": "string", "format": "date-time" },
              "endedAt": { "type": "string", "format": "date-time" }, "environment": { "const": "local-marketing-studio" },
              "observerRole": { "enum": ["non-intervening-observer", "automated-proxy"] }
            },
            "required": ["environment", "observerRole"]
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": { "enum": ["completed", "blocked", "abandoned"] }, "durationSeconds": { "type": "integer" },
                "hesitationCount": { "type": "integer" }, "blockageCount": { "type": "integer" }, "recoveryCount": { "type": "integer" },
                "result": { "enum": ["success", "partial", "failure"] }
              }
            }
          },
          "recommendation": {
            "type": "object",
            "properties": {
              "gate": { "enum": ["block", "conditional-go", "go"] },
              "realityCheck": { "$ref": "#/$defs/safeNote" }
            },
            "required": ["realityCheck"]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "recommendation": {
                  "type": "object",
                  "properties": { "gate": { "const": "go" } },
                  "required": ["gate"]
                }
              },
              "required": ["recommendation"]
            },
            "then": {
              "properties": {
                "session": {
                  "type": "object",
                  "properties": {
                    "operatorProfile": { "const": "target-nontechnical" },
                    "observerRole": { "const": "non-intervening-observer" },
                    "developmentAssistance": { "const": "none" }
                  }
                },
                "steps": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "status": { "const": "completed" },
                      "result": { "const": "success" }
                    }
                  }
                },
                "findings": {
                  "type": "array",
                  "not": {
                    "contains": {
                      "type": "object",
                      "properties": { "classification": { "const": "blocker" } },
                      "required": ["classification"]
                    }
                  }
                }
              }
            }
          }
        ,
          {
            "if": {
              "properties": {
                "session": {
                  "type": "object",
                  "properties": { "operatorProfile": { "const": "codex-operator-proxy" } },
                  "required": ["operatorProfile"]
                }
              },
              "required": ["session"]
            },
            "then": {
              "properties": {
                "session": {
                  "type": "object",
                  "properties": {
                    "observerRole": { "const": "automated-proxy" },
                    "developmentAssistance": { "const": "provided" }
                  }
                },
                "recommendation": {
                  "type": "object",
                  "properties": { "gate": { "enum": ["block", "conditional-go"] } }
                }
              }
            }
          }
        ]
      }
    }
  ]
}
