{
  "name": "academia-lendaria-ads-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/start.ts",
    "studio": "node ../../scripts/marketing-studio.mjs start",
    "studio:check": "node ../../scripts/marketing-studio.mjs check",
    "studio:status": "node ../../scripts/marketing-studio.mjs status",
    "studio:stop": "node ../../scripts/marketing-studio.mjs stop",
    "catalog:generate": "node ../../scripts/generate-skill-catalog.mjs",
    "catalog:validate": "node ../../scripts/validate-skill-catalog.mjs",
    "prebuild": "npm run catalog:generate && npm run catalog:validate",
    "pretypecheck": "npm run catalog:generate && npm run catalog:validate",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "node e2e/story-8-w3-2.mjs",
    "test:e2e:onboarding": "node e2e/story-9-w1-onboarding.mjs",
    "test:e2e:launcher": "node e2e/story-8-w3-3.mjs",
    "test:launcher": "node --test ../../scripts/marketing-studio.test.mjs",
    "test:watch": "vitest",
    "test:visual": "node scripts/visual-qa.mjs",
    "test:db": "supabase test db",
    "lint:db": "supabase db lint --local --level warning",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node dist/server/start.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-router": "^1.169.1",
    "@trpc/server": "^11.0.0",
    "fastify": "^5.8.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.9.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.3.0",
    "playwright": "1.61.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
